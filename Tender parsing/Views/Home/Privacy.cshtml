public class TenderService : ITenderService
{
    private readonly IHttpClientFactory _httpClientFactory;
    private readonly ITenderHtmlParser _htmlParser;
    
    public TenderService(
        IHttpClientFactory httpClientFactory,
        ITenderHtmlParser htmlParser)
    {
        _httpClientFactory = httpClientFactory;
        _htmlParser = htmlParser;
    }
    
    public async Task&lt;CompleteTenderInfo&gt; GetCompleteTenderInfoAsync(int tenderId)
    {
        // Шаг 1: Получаем базовую информацию через API
        var basicInfo = await GetBasicTenderInfoAsync(tenderId);
        if (basicInfo == null) return null;
        
        // Шаг 2: Парсим HTML страницу извещения
        var html = await GetTradePageHtmlAsync(tenderId);
        var additionalInfo = await _htmlParser.ParseAdditionalInfoAsync(html);
        
        // Шаг 3: Получаем список документации
        var documents = await GetTenderDocumentsAsync(tenderId);
        
        return new CompleteTenderInfo
        {
            BasicInfo = basicInfo,
            AdditionalInfo = additionalInfo,
            Documents = documents
        };
    }
}
