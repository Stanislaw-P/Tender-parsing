@model TenderSearchViewModel

@{
    ViewData["Title"] = "Поиск тендера";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-white text-center rounded-top-4" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                    <i class="fas fa-gavel fa-3x mb-2"></i>
                    <h3 class="mb-0">Поиск тендера</h3>
                    <p class="mb-0 mt-2 small">Электронная торговая площадка Московской области</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Search" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="TenderId" class="form-label fw-bold">
                                <i class="fas fa-hashtag text-primary"></i> Номер тендера
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-primary text-white border-0">
                                    <i class="fas fa-file-signature"></i>
                                </span>
                                <input asp-for="TenderId"
                                       class="form-control form-control-lg"
                                       placeholder="Например: 1763198"
                                       autocomplete="off">
                            </div>
                            <span asp-validation-for="TenderId" class="text-danger small"></span>
                            <div class="form-text">
                                <i class="fas fa-info-circle"></i> Введите цифровой номер тендера
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3" style="background: linear-gradient(135deg, #667eea, #764ba2); border: none;">
                            <i class="fas fa-search me-2"></i> Найти тендер
                        </button>
                    </form>

                    <div class="alert alert-info small mt-3">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Информация:</strong> Будет получена полная информация о тендере,
                        включая состав лота, место поставки и документацию.
                    </div>
                </div>
            </div>

            <div class="text-center mt-4 text-white">
                <small>
                    <i class="fas fa-database me-1"></i> Данные получены через официальное API
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}