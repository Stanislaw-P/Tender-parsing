@model TenderSearchViewModel

@{
    ViewData["Title"] = "Поиск тендера";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h3>
                        <i class="fas fa-gavel"></i> Поиск тендера
                    </h3>
                    <p class="mb-0">Электронная торговая площадка Московской области</p>
                </div>
                <div class="card-body">
                    <form asp-action="Search" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="TenderId" class="form-label">
                                <i class="fas fa-hashtag"></i> Номер тендера
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-file-signature"></i>
                                </span>
                                <input asp-for="TenderId" class="form-control"
                                       placeholder="Например: 1763198">
                            </div>
                            <span asp-validation-for="TenderId" class="text-danger"></span>
                            <small class="form-text text-muted">
                                Введите цифровой номер тендера
                            </small>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search"></i> Найти тендер
                        </button>
                    </form>

                    <div class="mt-3 p-3 bg-light rounded">
                        <small>
                            <i class="fas fa-info-circle text-primary"></i>
                            <strong>Информация:</strong> Будет получена полная информация о тендере,
                            включая состав лота и документацию.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}