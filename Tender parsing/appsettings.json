{
  "Serilog": {
    // 1. Указываем, какие пакеты (Sinks) мы будем использовать
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    // 2. Настраиваем минимальный уровень логирования
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning", // Логи от ASP.NET Core менее подробные
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    // 3. Настраиваем КУДА писать логи (WriteTo)
    "WriteTo": [
      // Консоль (для наглядности при запуске)
      { "Name": "Console" },
      // Файлы в JSON формате
      {
        "Name": "File",
        "Args": {
          // ВАЖНО: путь к папке с логами
          "path": "Logs/log-.json",
          // Форматтер для записи в JSON
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog",
          // Новый файл каждый день
          "rollingInterval": "Day",
          // Хранить файлы 7 дней
          "retainedFileCountLimit": 7,
          // Максимальный размер файла 10 МБ
          "fileSizeLimitBytes": 10485760,
          // Создавать новый файл при достижении лимита
          "rollOnFileSizeLimit": true
        }
      }
    ],
    // 4. Обогащаем логи дополнительной информацией (Enrich)
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
